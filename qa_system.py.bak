                self.excel_path = excel_path
                
                # 结果输出配置
                timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
                self.result_dir = f"./data_test_result_{timestamp}"
                os.makedirs(self.result_dir, exist_ok=True)
                os.makedirs(os.path.join(self.result_dir, "dialog_extractions"), exist_ok=True)
                os.makedirs(os.path.join(self.result_dir, "cluster_details"), exist_ok=True)
        
        config = StreamlitConfig()
        
        # 初始化 OpenAI 客户端
        def init_openai_client(config):
            client = OpenAI(
                base_url=config.base_url.strip(),
                api_key=config.api_key
            )
            return client
        
        # BGE嵌入生成器
        class BGEEmbeddingGenerator:
            def __init__(self, config):
                self.local_model_path = config.bge_model_path
                self.config = config
                
                if not os.path.exists(self.local_model_path):
                    st.warning(f"⚠️ BGE 模型路径不存在: {self.local_model_path}，将使用在线下载")
                
                self.model = SentenceTransformer(self.local_model_path, device=config.embedding_device)
            
            def get_embedding(self, question):
                return self.model.encode(question, normalize_embeddings=True, show_progress_bar=False)
        
        # QA 提取模块
        class QAPairExtractor:
            def __init__(self, client, config):
                self.client = client
                self.config = config
                self.extract_prompt = """你需要从以下客服对话记录中提取**信息咨询类问答对**，并严格遵守以下规则：
1.  仅提取客户提出的**信息寻求类问题**，忽略寒暄、闲聊、个人隐私内容（如手机号、姓名）。
2.  答案必须来自客服的回复，可适当改写口语化表述，但不能添加额外信息。
3.  排除时效性内容（如仅限某日有效）和特定客户的专属内容。
4.  若问题涉及产品，必须在问答对中明确提及产品名称。
5.  输出格式为JSON数组，每个元素包含"question"和"answer"两个字段，不要添加任何其他内容。

对话记录：
{transcript}

提取的问答对："""
            
            def extract_qa_from_transcript(self, transcript):
                if not transcript or not isinstance(transcript, str) or len(transcript.strip()) < self.config.min_dialog_length:
                    return []
                
                formatted_prompt = self.extract_prompt.format(transcript=transcript.strip())
                
                try:
                    response = self.client.chat.completions.create(
                        model=self.config.model_name,
                        messages=[{"role": "user", "content": formatted_prompt}],
                        temperature=self.config.temperature,
                        max_tokens=self.config.max_tokens,
                        top_p=self.config.top_p
                    )
                    
                    output = response.choices[0].message.content.strip()
                    output = re.sub(r'(\<think\>[\s\S]*?\<\/think\>)|(\<\|thinking\|\>[\s\S]*?\<\/\|thinking\|\>)', '', output)
                    
                    try:
                        qa_pairs = json.loads(output)
                        if not isinstance(qa_pairs, list):
                            return []
                        
                        valid_pairs = []
                        for qa in qa_pairs:
                            if (isinstance(qa, dict) and 
                                "question" in qa and 
                                "answer" in qa and 
                                isinstance(qa["question"], str) and 
                                isinstance(qa["answer"], str) and
                                len(qa["question"].strip()) >= self.config.min_question_length):
                                valid_pairs.append({
                                    "question": qa["question"].strip(),
                                    "answer": qa["answer"].strip()
                                })
                        return valid_pairs
                    except json.JSONDecodeError:
                        return []
                except Exception as e:
                    st.toast(f"⚠️ API 调用失败: {str(e)}")
                    return []
        
        # 聚类与筛选模块
        class QAClusterAndSelector:
            def __init__(self, client, config, embedding_generator):
                self.client = client
                self.config = config
                self.embedding_generator = embedding_generator
                
                self.select_prompt = """你需要从以下**语义相似的QA对聚类**中，筛选出1-2个**代表性问答对**，并严格遵守以下规则：
1.  代表性QA对需覆盖聚类的核心信息，表述简洁通用，适用于未来客户。
2.  合并重复内容，优先选择答案完整、适用范围广的QA对。
3.  排除时效性、个性化、含隐私的内容；涉及产品时必须明确产品名。
4.  输出格式为JSON数组，每个元素包含"representative_question"和"representative_answer"字段，不要添加其他内容。

QA对聚类：
{cluster_qa_text}

代表性问答对："""
            
            def cluster_qa_pairs(self, all_qa_pairs):
                if len(all_qa_pairs) < 2:
                    return {0: all_qa_pairs}
                
                # 1. 生成所有问题的嵌入
                questions = [qa["question"] for qa in all_qa_pairs]
                embeddings = []
                
                for i, q in enumerate(questions):
                    progress = (i + 1) / (len(questions) * 2)
                    progress_bar.progress(progress)
                    status_placeholder.info(f"生成问题嵌入: {i+1}/{len(questions)}")
                    
                    # 直接使用 BGE 生成嵌入，删除 qwen 选项
                    emb = self.embedding_generator.get_embedding(q)
                    embeddings.append(emb)
                
                embeddings = np.array(embeddings)
                
                # 2. 执行 DBSCAN 聚类
                if len(embeddings) > 1:
                    distance_matrix = cosine_distances(embeddings)
                    upper_triangle = distance_matrix[np.triu_indices_from(distance_matrix, k=1)]
                    distance_median = np.median(upper_triangle)
                    dynamic_eps = max(self.config.min_eps_value, min(self.config.max_eps_value, distance_median * self.config.dynamic_eps_coefficient))
                    st.info(f"✅ 动态计算 eps: {dynamic_eps:.3f}（距离中位数：{distance_median:.3f}）")
                else:
                    dynamic_eps = 0.2
                
                dbscan = DBSCAN(
                    eps=dynamic_eps,
                    min_samples=self.config.dbscan_min_samples,
                    metric=self.config.clustering_metric
                )
                labels = dbscan.fit_predict(embeddings)
                
                # 3. 整理聚类结果
                clusters = {}
                for idx, label in enumerate(labels):
                    if label not in clusters:
                        clusters[label] = []
                    clusters[label].append(all_qa_pairs[idx])
                
                status_placeholder.success(f"✅ 聚类完成，共生成 {len(clusters)} 个簇（标签 -1 为噪声簇）")
                return clusters
            
            def select_representative_qa(self, cluster_qa_list):
                if not cluster_qa_list:
                    return []
                
                # 格式化聚类中的QA对
                qa_to_use = cluster_qa_list if self.config.max_cluster_qa_count is None else cluster_qa_list[:self.config.max_cluster_qa_count]
                cluster_qa_text = "\n".join([f"Q: {qa['question']}\nA: {qa['answer']}" for qa in qa_to_use])
                formatted_input = cluster_qa_text[:self.config.max_input_length]
                formatted_prompt = self.select_prompt.format(cluster_qa_text=formatted_input)
                
                try:
                    response = self.client.chat.completions.create(
                        model=self.config.model_name,
                        messages=[{"role": "user", "content": formatted_prompt}],
                        temperature=self.config.temperature,
                        max_tokens=self.config.max_tokens,
                        top_p=self.config.top_p
                    )
                    
                    output = response.choices[0].message.content.strip()
                    output = re.sub(r'(\<think\>[\s\S]*?\<\/think\>)|(\<\|thinking\|\>[\s\S]*?\<\/\|thinking\|\>)', '', output)
                    
                    try:
                        result = json.loads(output)
                        if isinstance(result, list):
                            return [{
                                "representative_question": item["representative_question"].strip(),
                                "representative_answer": item["representative_answer"].strip()
                            } for item in result if 
                                isinstance(item, dict) and 
                                "representative_question" in item and 
                                "representative_answer" in item]
                        return []
                    except json.JSONDecodeError:
                        return []
                except Exception as e:
                    st.toast(f"⚠️ 代表性 QA 筛选失败: {str(e)}")
                    return []
        
        # 安全保存 JSON
        def save_json_safe(data, filepath, description=""):
            try:
                cleaned_data = convert_numpy_types(data)
                with open(filepath, "w", encoding="utf-8") as f:
                    json.dump(cleaned_data, f, ensure_ascii=False, indent=2)
                return True
            except Exception as e:
                st.toast(f"❌ 保存 {description} 失败: {str(e)}")
                return False
        
        # ========== 开始处理流程 ==========
        start_time = time.time()
        
        try:
            # 1. 初始化客户端
            client = init_openai_client(config)
            status_placeholder.info("✅ OpenAI 客户端初始化成功")
            
            # 2. 初始化嵌入生成器
            embedding_generator = None
            if config.embedding_method == "bge":
                try:
                    status_placeholder.info("🚀 初始化 BGE 嵌入模型...")
                    embedding_generator = BGEEmbeddingGenerator(config)
                    status_placeholder.success("✅ BGE 嵌入模型加载成功")
                except Exception as e:
                    st.warning(f"⚠️ BGE 模型加载失败: {str(e)}")
            
            # 3. 初始化处理模块
            qa_extractor = QAPairExtractor(client, config)
            qa_cluster_selector = QAClusterAndSelector(client, config, embedding_generator)
            
            # 4. 读取 Excel 数据
            status_placeholder.info(f"📂 读取 Excel 文件: {excel_path}")
            
            try:
                df = pd.read_excel(config.excel_path, usecols=[3])  # 读取 D 列
                df.columns = ['dialog']
                
                if config.excel_row_limit is None:
                    dialog_texts = df['dialog'].dropna().astype(str).tolist()
                else:
                    dialog_texts = df['dialog'].dropna().astype(str).head(config.excel_row_limit).tolist()
                
                status_placeholder.success(f"✅ 成功加载 {len(dialog_texts)} 条对话记录")
            except Exception as e:
                st.error(f"❌ 读取 Excel 失败: {str(e)}")
                st.stop()
            
            # 5. 提取 QA 对
            status_placeholder.info(f"🔍 开始提取问答对 (共 {len(dialog_texts)} 条对话)...")
            all_qa_pairs = []
            valid_count = 0
            
            for idx, transcript in enumerate(dialog_texts, 1):
                progress = 0.5 + (idx / len(dialog_texts)) * 0.3  # 提取 QA 占总进度的 30%
                progress_bar.progress(progress)
                status_placeholder.info(f"处理对话 #{idx}/{len(dialog_texts)}")
                
                qa_list = qa_extractor.extract_qa_from_transcript(transcript)
                
                if qa_list:
                    valid_count += 1
                    # 保存单个对话结果
                    dialog_result = {
                        "dialog_index": idx,
                        "full_dialog_text": transcript,  # 保存完整对话
                        "dialog_preview": transcript[:200] + "..." if len(transcript) > 200 else transcript,  # 仅用于预览
                        "extracted_qa_pairs": qa_list,
                        "extraction_count": len(qa_list),
                        "success": True
                    }
                    dialog_file = os.path.join(config.result_dir, "dialog_extractions", f"dialog_{idx}.json")
                    save_json_safe(dialog_result, dialog_file, f"对话 #{idx}")
                
                all_qa_pairs.extend(qa_list)
            
            # 保存原始 QA 对
            raw_qa_file = os.path.join(config.result_dir, "raw_qa_pairs.json")
            save_json_safe(all_qa_pairs, raw_qa_file, "原始 QA 对")
            
            status_placeholder.success(f"✅ 共提取 {len(all_qa_pairs)} 个 QA 对 (来自 {valid_count}/{len(dialog_texts)} 个对话)")
            
            if len(all_qa_pairs) == 0:
                st.error("❌ 未提取到任何问答对，请检查对话数据或参数配置")
                st.stop()
            
            # 6. 聚类
            status_placeholder.info("🧩 开始聚类分析...")
            clusters = qa_cluster_selector.cluster_qa_pairs(all_qa_pairs)
            
            # 保存聚类结果
            cluster_results = {
                "cluster_count": len(clusters),
                "noise_cluster_count": len(clusters.get(-1, [])),
                "total_qa_pairs": len(all_qa_pairs),
                "clusters": {str(label): {"size": len(qa_list), "qa_pairs": qa_list} for label, qa_list in clusters.items()}
            }
            
            cluster_file = os.path.join(config.result_dir, "cluster_results.json")
            save_json_safe(cluster_results, cluster_file, "聚类结果")
            
            # 7. 筛选代表性 QA
            status_placeholder.info("🌟 筛选代表性问答对...")
            final_representative_qa = []
            sorted_clusters = sorted(clusters.items(), key=lambda x: len(x[1]), reverse=True)
            
            for i, (label, cluster_qa) in enumerate(sorted_clusters):
                if label == -1 or len(cluster_qa) == 0:
                    continue
                
                progress = 0.8 + (i / len(sorted_clusters)) * 0.2  # 筛选代表性 QA 占总进度的 20%
                progress_bar.progress(progress)
                status_placeholder.info(f"处理簇 #{label} ({i+1}/{len(sorted_clusters)})")
                
                representative_qa = qa_cluster_selector.select_representative_qa(cluster_qa)
                
                if representative_qa:
                    final_representative_qa.extend(representative_qa)
                elif config.use_backup_strategy and cluster_qa:
                    final_representative_qa.append({
                        "representative_question": cluster_qa[0]["question"],
                        "representative_answer": cluster_qa[0]["answer"]
                    })
            
            # 8. 保存结果
            rep_qa_file = os.path.join(config.result_dir, "representative_qa_pairs.json")
            save_json_safe(final_representative_qa, rep_qa_file, "代表性 QA 对")
            
            # 保存每个簇的详细内容
            cluster_details_dir = os.path.join(config.result_dir, "cluster_details")
            os.makedirs(cluster_details_dir, exist_ok=True)
            for i, (label, cluster_qa) in enumerate(clusters.items()):
                if isinstance(cluster_qa, list) and len(cluster_qa) > 0:
                    cluster_file = os.path.join(cluster_details_dir, f"cluster_{label}.json")
                    cluster_data = {
                        "cluster_id": label,
                        "size": len(cluster_qa),
                        "qa_pairs": cluster_qa
                    }
                    save_json_safe(cluster_data, cluster_file, f"簇 #{label} 详细内容")

            # 9. 保存统计信息
            processing_time = time.time() - start_time
            stats = {
                "start_time": datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
                "processing_time_seconds": round(processing_time, 2),
                "total_dialogs_processed": len(dialog_texts),
                "dialogs_with_valid_qa": valid_count,
                "total_raw_qa_pairs": len(all_qa_pairs),
                "total_clusters": len(clusters),
                "noise_cluster_size": len(clusters.get(-1, [])),
                "final_representative_qa_count": len(final_representative_qa),
                "success_rate": f"{valid_count/len(dialog_texts)*100:.1f}%",
                "qa_extraction_rate": f"{len(all_qa_pairs)/len(dialog_texts):.2f} QA/对话",
                "representative_qa_rate": f"{len(final_representative_qa)/len(all_qa_pairs)*100:.1f}%"
            }
            
            stats_file = os.path.join(config.result_dir, "processing_stats.json")
            save_json_safe(stats, stats_file, "处理统计")
            
            # 10. 保存到 session state
            st.session_state.processing_results = {
                'stats': stats,
                'representative_qa': final_representative_qa,
                'clusters': clusters,
                'all_qa_pairs': all_qa_pairs,
                'result_dir': config.result_dir
            }
            st.session_state.stats = stats
            st.session_state.representative_qa = final_representative_qa
            st.session_state.clusters = clusters
            st.session_state.processing_time = processing_time
            st.session_state.result_dir = config.result_dir
            
            progress_bar.progress(1.0)
            status_placeholder.success(f"🎉 处理完成！总耗时: {processing_time:.2f} 秒")
            st.rerun()
        
        except Exception as e:
            st.error(f"❌ 处理过程中出错: {str(e)}")
            st.exception(e)

    # ==================== 结果展示 ====================
    if st.session_state.processing_results:
        results = st.session_state.processing_results
        stats = results['stats']
        representative_qa = results['representative_qa']
        clusters = results['clusters']
        all_qa_pairs = results['all_qa_pairs']
        result_dir = results['result_dir']
        
        # 统计摘要
        st.subheader("📈 处理统计摘要")
        col1, col2, col3, col4 = st.columns(4)
        col1.metric("总耗时", f"{stats['processing_time_seconds']} 秒")
        col2.metric("对话成功率", stats['success_rate'])
        col3.metric("QA提取率", stats['qa_extraction_rate'])
        col4.metric("最终QA数量", stats['final_representative_qa_count'])
        
        # 聚类详情展示
        st.subheader("🔍 聚类详情")
        if clusters:
            valid_clusters = [(label, qa_list) for label, qa_list in clusters.items() if isinstance(qa_list, list) and len(qa_list) > 0]
            if valid_clusters:
                clusters_per_page = 10
                total_pages = (len(valid_clusters) + clusters_per_page - 1) // clusters_per_page
                if 'current_cluster_page' not in st.session_state:
                    st.session_state.current_cluster_page = 1
                current_page = st.number_input('页码', min_value=1, max_value=total_pages, value=st.session_state.current_cluster_page,key='cluster_page_input')
                if current_page != st.session_state.current_cluster_page:
                    st.session_state.current_cluster_page = current_page
                    st.rerun()
                st.caption(f"第 {st.session_state.current_cluster_page}/{total_pages} 页，共 {len(valid_clusters)} 个簇")
                start_idx = (st.session_state.current_cluster_page - 1) * clusters_per_page
                end_idx = start_idx + clusters_per_page
                page_clusters = valid_clusters[start_idx:end_idx]
                for label, qa_list in page_clusters:
                    with st.expander(f"簇 #{label} - 共 {len(qa_list)} 个问答对"):
                        qa_df = pd.DataFrame(qa_list)
                        if not qa_df.empty:
                            qa_df['question_preview'] = qa_df['question'].apply(lambda x: x[:max_preview_chars] + '...' if len(x) > max_preview_chars else x)
                            qa_df['answer_preview'] = qa_df['answer'].apply(lambda x: x[:max_preview_chars] + '...' if len(x) > max_preview_chars else x)
                            display_df = qa_df[['question_preview', 'answer_preview']]
                            display_df.columns = ['问题预览', '回答预览']
                            st.dataframe(display_df, width='stretch',height=min(250, len(qa_list) * 35 + 40))
                            if st.checkbox(f"查看簇 #{label} 的完整问答对", key=f"full_qa_{label}"):
                                st.markdown('<div style="max-height: 300px; overflow-y: auto; border: 1px solid #e9ecef; border-radius: 5px; padding: 10px;">',unsafe_allow_html=True)
                                for i, qa in enumerate(qa_list, 1):
                                    st.markdown(f"**Q{i}:** {qa['question']}")
                                    st.markdown(f"**A{i}:** {qa['answer']}")
                                    st.markdown("---")
                                st.markdown('</div>', unsafe_allow_html=True)
            else:
                st.info("没有可用的聚类数据可供展示")
        
        # 簇详情表格概览
        st.subheader("📊 所有簇概览")
        if clusters:
            cluster_summary = []
            for label, qa_list in clusters.items():
                if isinstance(qa_list, list):
                    cluster_summary.append({
                        "簇ID": label,
                        "QA对数量": len(qa_list),
                        "噪声簇": "是" if label == -1 else "否"
                    })
            if cluster_summary:
                summary_df = pd.DataFrame(cluster_summary)
                summary_df = summary_df.sort_values(by="QA对数量", ascending=False)
                st.dataframe(summary_df, width='stretch')
                total_clusters = len([c for c in clusters if isinstance(clusters[c], list) and len(clusters[c]) > 0])
                noise_cluster_size = len(clusters.get(-1, [])) if isinstance(clusters.get(-1, []), list) else 0
                total_qa_pairs = sum(len(qa_list) for qa_list in clusters.values() if isinstance(qa_list, list))
                st.caption(f"总簇数: {total_clusters} | 噪声簇大小: {noise_cluster_size} | 总QA对数: {total_qa_pairs}")
            else:
                st.info("没有可用的聚类数据")
        
        # 原始提取的QA对展示
        st.subheader(f"📋 原始提取的 QA 对 ({len(all_qa_pairs)} 个)")
        if all_qa_pairs:
            qa_df = pd.DataFrame(all_qa_pairs)
            qa_df.insert(0, '序号', range(1, len(qa_df) + 1))
            qa_df['question_preview'] = qa_df['question'].apply(lambda x: x[:max_preview_chars] + '...' if len(x) > max_preview_chars else x)
            qa_df['answer_preview'] = qa_df['answer'].apply(lambda x: x[:max_preview_chars] + '...' if len(x) > max_preview_chars else x)
            display_columns = ['序号', 'question_preview', 'answer_preview']
            column_names = ['序号', '问题预览', '回答预览']
            st.dataframe(qa_df[display_columns].rename(columns=dict(zip(display_columns, column_names))), width='stretch',height=min(400, len(all_qa_pairs) * 35 + 40))
            qa_pair_options = [f"QA对 #{i+1}: {qa['question'][:50]}{'...' if len(qa['question'])>50 else ''}" for i, qa in enumerate(all_qa_pairs)]
            selected_qa = st.selectbox("选择要查看的QA对:", [""] + qa_pair_options)
            if selected_qa:
                qa_index = qa_pair_options.index(selected_qa)
                qa = all_qa_pairs[qa_index]
                st.markdown(f"### 问题:")
                st.markdown(f"**{qa['question']}**")
                st.markdown(f"### 回答:")
                st.markdown(f"{qa['answer']}")
                cluster_info = []
                for label, qa_list in clusters.items():
                    if isinstance(qa_list, list):
                        for cluster_qa in qa_list:
                            if cluster_qa['question'] == qa['question'] and cluster_qa['answer'] == qa['answer']:
                                cluster_info.append(f"簇 #{label}")
                if cluster_info:
                    st.info(f"该QA对属于: {', '.join(cluster_info)}")
                else:
                    st.warning("该QA对未被分配到任何簇中")
        else:
            st.info("没有原始 QA 对可供展示")
        
        # 对话提取结果
        st.subheader("📂 对话提取结果")
        dialog_extractions_dir = os.path.join(result_dir, "dialog_extractions")
        if os.path.exists(dialog_extractions_dir):
            dialog_files = sorted([f for f in os.listdir(dialog_extractions_dir) if f.endswith('.json')])
            if dialog_files:
                dialog_data = []
                for file in dialog_files:
                    file_path = os.path.join(dialog_extractions_dir, file)
                    with open(file_path, 'r', encoding='utf-8') as f:
                        data = json.load(f)
                        dialog_data.append({
                            "对话索引": data.get("dialog_index", "N/A"),
                            "QA数量": data.get("extraction_count", 0),
                            "状态": "✅" if data.get("success", False) else "❌",
                            "预览": data.get("dialog_preview", data.get("dialog_text", ""))[:100] + "..."
                        })
                df_dialogs = pd.DataFrame(dialog_data)
                st.dataframe(df_dialogs, width='stretch')
                selected_dialog = st.selectbox("选择一个对话查看详细提取结果：", [""] + [f"对话 {item['对话索引']}" for item in dialog_data])
                if selected_dialog:
                    dialog_index = int(selected_dialog.split()[1])
                    file_path = os.path.join(dialog_extractions_dir, f"dialog_{dialog_index}.json")
                    if os.path.exists(file_path):
                        with open(file_path, 'r', encoding='utf-8') as f:
                            dialog_result = json.load(f)
                        st.subheader(f"对话 #{dialog_index} 详情")
                        st.text_area("完整对话内容", dialog_result.get("full_dialog_text", ""),height=150,max_chars=None)
                        if dialog_result["success"] and dialog_result["extracted_qa_pairs"]:
                            st.success(f"✅ 成功提取 {len(dialog_result['extracted_qa_pairs'])} 个QA对")
                            for i, qa in enumerate(dialog_result["extracted_qa_pairs"], 1):
                                with st.expander(f"QA对 #{i}"):
                                    st.markdown(f"**问题:** {qa['question']}")
                                    st.markdown(f"**回答:** {qa['answer']}")
                        else:
                            st.warning("❌ 该对话未提取到任何QA对")
            else:
                st.info("目录中未找到对话提取结果。")
        else:
            st.warning("对话提取目录未找到。")
        
        # 代表性问答对
        st.subheader(f"🎯 代表性问答对 ({len(representative_qa)} 个)")
        if representative_qa:
            qa_per_page = 10
            total_pages = (len(representative_qa) + qa_per_page - 1) // qa_per_page
            if 'current_rep_qa_page' not in st.session_state:
                st.session_state.current_rep_qa_page = 1
            current_page = st.number_input('页码', min_value=1, max_value=total_pages, value=st.session_state.current_rep_qa_page,key='rep_qa_page_input')
            if current_page != st.session_state.current_rep_qa_page:
                st.session_state.current_rep_qa_page = current_page
                st.rerun()
            st.caption(f"第 {st.session_state.current_rep_qa_page}/{total_pages} 页，共 {len(representative_qa)} 个QA对")
            start_idx = (st.session_state.current_rep_qa_page - 1) * qa_per_page
            end_idx = start_idx + qa_per_page
            page_qa = representative_qa[start_idx:end_idx]
            scroll_container = st.container()
            with scroll_container:
                st.markdown('<div style="max-height: 400px; overflow-y: auto; padding-right: 10px;">', unsafe_allow_html=True)
                for i, qa in enumerate(page_qa, start=start_idx+1):
                    with st.expander(f"Q{i}: {qa['representative_question'][:50]}{'...' if len(qa['representative_question'])>50 else ''}"):
                        st.markdown(f"**问题:** {qa['representative_question']}")
                        st.markdown(f"**回答:** {qa['representative_answer']}")
                st.markdown('</div>', unsafe_allow_html=True)
        else:
            st.info("没有生成代表性问答对")
        
        # 结果下载
        st.subheader("📥 结果下载")
        col1, col2, col3 = st.columns(3)
        with col1:
            with open(os.path.join(result_dir, "representative_qa_pairs.json"), 'r', encoding='utf-8') as f:
                st.download_button('⬇️ 代表性QA对', f.read(), 'representative_qa_pairs.json', 'application/json',width='stretch')
        with col2:
            with open(os.path.join(result_dir, "cluster_results.json"), 'r', encoding='utf-8') as f:
                st.download_button('⬇️ 聚类结果', f.read(), 'cluster_results.json', 'application/json',width='stretch')
        with col3:
            cluster_details_zip = os.path.join(result_dir, "cluster_details.zip")
            import zipfile
            with zipfile.ZipFile(cluster_details_zip, 'w') as zipf:
                for root, dirs, files in os.walk(os.path.join(result_dir, "cluster_details")):
                    for file in files:
                        file_path = os.path.join(root, file)
                        zipf.write(file_path, os.path.relpath(file_path, os.path.join(result_dir, "cluster_details")))
            with open(cluster_details_zip, 'rb') as f:
                st.download_button('⬇️ 所有簇详情', f.read(), 'cluster_details.zip', 'application/zip',width='stretch')
        col4,col5, col6 = st.columns(3)
        with col4:
            with open(os.path.join(result_dir, "raw_qa_pairs.json"), 'r', encoding='utf-8') as f:
                st.download_button('⬇️ 原始QA对', f.read(), 'raw_qa_pairs.json', 'application/json',width='stretch')
        with col5:
            dialog_extractions_zip = os.path.join(result_dir, "dialog_extractions.zip")
            with zipfile.ZipFile(dialog_extractions_zip, 'w') as zipf:
                for root, dirs, files in os.walk(os.path.join(result_dir, "dialog_extractions")):
                    for file in files:
                        file_path = os.path.join(root, file)
                        zipf.write(file_path, os.path.relpath(file_path, os.path.join(result_dir, "dialog_extractions")))
            with open(dialog_extractions_zip, 'rb') as f:
                st.download_button('⬇️ 对话提取结果', f.read(), 'dialog_extractions.zip', 'application/zip',width='stretch')
        with col6:
            with open(os.path.join(result_dir, "processing_stats.json"), 'r', encoding='utf-8') as f:
                st.download_button('⬇️ 处理统计', f.read(), 'processing_stats.json', 'application/json',width='stretch')
        
        # 结果目录
        st.subheader("📁 结果目录")
        st.code(result_dir)
    else:
        st.info("ℹ️ 请在侧边栏配置参数后点击「开始处理」按钮，或加载历史结果查看")

# ==================== 5. Tab2: 知识库管理（最终版：已有问题+相似问题均显示答案+动态更新） ====================
with tab2:
    st.subheader("📚 知识库管理")
    st.markdown("将历史分析结果导入知识库，支持相似度比对和人工确认")
    st.markdown("---")
    
    # 初始化会话状态
    for key in ['kb_instance', 'kb_selected_dir', 'kb_analysis_results', 'embedding_generator', 'similarity_analysis']:
        if key not in st.session_state:
            st.session_state[key] = None
    if 'kb_auto_init_done' not in st.session_state:
        st.session_state.kb_auto_init_done = False
    
    # 自动初始化知识库
    auto_init_knowledge_base()
    
    # 1. 加载历史结果和知识库操作区
    col1, col2 = st.columns([2, 1])
    with col1:
        result_dirs = [d for d in os.listdir('.') if d.startswith('data_test_result_') and os.path.isdir(d)]
        if result_dirs:
            selected_dir = st.selectbox("选择要导入的历史结果", sorted(result_dirs, reverse=True), index=0)
            if st.button("加载结果", key="kb_load"):
                st.session_state.similarity_analysis = None  # 清除旧分析结果
                results = load_results(selected_dir)
                if results:
                    st.session_state.kb_selected_dir = selected_dir
                    st.session_state.kb_analysis_results = results
                    st.success(f"✅ 已加载结果: {selected_dir}")
                    st.rerun()  # 加载结果需要刷新，保留这个rerun
        # 重新初始化按钮（无刷新，提示永久显示）
        if st.button("🔄 重新初始化知识库", key="reinit_kb"):
            st.session_state.kb_auto_init_done = False
            st.session_state.similarity_analysis = None
            auto_init_knowledge_base()
            st.session_state['kb_reinit_success'] = True  # 标记初始化成功
        
       
    
    with col2:
        st.info("📊 知识库统计")
        if st.session_state.kb_instance:
            kb = st.session_state.kb_instance
            st.metric("问答对数量", len(kb.knowledge_base))
            st.metric("问题相似度阈值", f"{similarity_threshold:.2f}")
            st.metric("答案相似度阈值", f"{answer_similarity_threshold:.2f}")
        else:
            st.warning("知识库初始化中...")
    
    st.markdown("---")
    
    # 2. 分析并比对相似度（基础逻辑不变）
    if st.session_state.kb_instance and st.session_state.kb_analysis_results:
        kb = st.session_state.kb_instance
        analysis_results = st.session_state.kb_analysis_results
        representative_qa = analysis_results['representative_qa']
        
        st.subheader(f"🔍 相似度分析 ({len(representative_qa)} 个代表性问答对)")
        
        # 重新计算相似度分析（基础逻辑不变）
        if st.session_state.similarity_analysis is None:
            similarity_analysis = []
            progress_bar = st.progress(0)
            status_text = st.empty()
            for i, qa in enumerate(representative_qa):
                status_text.info(f"分析 QA 对 {i+1}/{len(representative_qa)}")
                progress_bar.progress((i+1)/len(representative_qa))
                question = qa['representative_question']
                answer = qa['representative_answer']
                similar_questions = kb.find_similar_questions(question, similarity_threshold)
                analysis_result = {
                    "index": i,
                    "question": question,
                    "answer": answer,
                    "similar_questions": similar_questions,
                    "is_new": len(similar_questions) == 0,
                    "action": None,  # 标记状态：added/updated/None
                    "selected_similar_index": None
                }
                # 计算答案相似度
                if similar_questions:
                    answer_similarities = []
                    for sim_q in similar_questions:
                        ans_sim = kb.get_answer_embedding_similarity(answer, sim_q['answer'])
                        answer_similarities.append({
                            "similarity": ans_sim,
                            "need_update": ans_sim < answer_similarity_threshold,
                            "existing_answer": sim_q['answer'],
                            "new_answer": answer,
                            "index": sim_q['index'],
                            "action": None  # 标记答案更新状态
                        })
                    analysis_result["answer_similarities"] = answer_similarities
                similarity_analysis.append(analysis_result)
            progress_bar.empty()
            status_text.empty()
            st.session_state.similarity_analysis = similarity_analysis
        
        # 取最新的相似度分析结果
        similarity_analysis = st.session_state.similarity_analysis

        # 动态筛选函数，每次渲染都重新计算分类
        def get_dynamic_categories():
            # 动态筛选：新问题（未添加）
            new_qs = [x for x in similarity_analysis if x['is_new'] and x.get('action') != 'added']
            # 动态筛选：需要更新（未更新）
            update_qs = []
            for x in similarity_analysis:
                if not x['is_new'] and x.get('answer_similarities'):
                    has_unupdated = any([ans['need_update'] and ans.get('action') != 'updated' for ans in x['answer_similarities']])
                    if has_unupdated:
                        update_qs.append(x)
            # 动态筛选：已有问题（已添加/已更新/无需更新）
            existing_qs = []
            for x in similarity_analysis:
                # 情况1：新问题已添加 → 归为已有问题
                if x['is_new'] and x.get('action') == 'added':
                    existing_qs.append(x)
                # 情况2：非新问题，无更新需求 或 所有更新都已完成
                elif not x['is_new']:
                    if not x.get('answer_similarities'):
                        existing_qs.append(x)
                    else:
                        all_updated = all([not ans['need_update'] or ans.get('action') == 'updated' for ans in x['answer_similarities']])
                        if all_updated:
                            existing_qs.append(x)
            return new_qs, update_qs, existing_qs
        
        # 每次渲染都重新获取动态分类
        new_questions, update_questions, existing_questions = get_dynamic_categories()

        # 动态生成标签页标题（计数实时更新）
        tab_new, tab_update, tab_existing = st.tabs([
            f"🆕 新问题 ({len(new_questions)})",
            f"🔄 需要更新 ({len(update_questions)})",
            f"✅ 已有问题 ({len(existing_questions)})"
        ])
        
        # 新问题标签页（正常显示问题+答案，供添加操作）
        with tab_new:
            if new_questions:
                for idx, item in enumerate(new_questions):
                    with st.expander(f"Q{item['index']+1}: {item['question'][:60]}{'...' if len(item['question'])>60 else ''}", expanded=True):
                        col1, col2 = st.columns([3, 1])
                        with col1:
                            st.markdown("**问题:**")
                            st.write(item['question'])
                            st.markdown("**回答:**")
                            st.write(item['answer'])
                        with col2:
                            st.markdown("### 操作")
                            if st.button(f"添加到知识库", key=f"add_{item['index']}"):
                                kb.add_qa_pair(item['question'], item['answer'])
                                kb.save_knowledge_base()
                                item['action'] = 'added'  # 标记已添加
                                st.session_state.similarity_analysis = similarity_analysis
                                st.success("✅ 已添加到知识库！")
                                st.rerun()  # 刷新触发重新分类
            else:
                st.info("✅ 暂无未添加的新问题（已添加的新问题已移至「已有问题」）")
        
        # 需要更新标签页（正常显示问题+答案，供更新操作）
        with tab_update:
            if update_questions:
                for idx, item in enumerate(update_questions):
                    with st.expander(f"Q{item['index']+1}: {item['question'][:60]}{'...' if len(item['question'])>60 else ''}", expanded=True):
                        st.markdown("**当前问题:**")
                        st.write(item['question'])
                        st.markdown("**新答案:**")
                        st.write(item['answer'])
                        st.markdown("---")
                        st.markdown("### 相似问题（需要更新答案）")
                        for ans_idx, ans_sim in enumerate(item['answer_similarities']):
                            if ans_sim['need_update'] and ans_sim.get('action') != 'updated':
                                col1, col2 = st.columns(2)
                                with col1:
                                    st.markdown(f"**现有答案 (相似度: {ans_sim['similarity']:.3f}):**")
                                    st.write(ans_sim['existing_answer'])
                                with col2:
                                    st.markdown("**新答案:**")
                                    st.write(ans_sim['new_answer'])
                                st.markdown("### 操作")
                                if st.button(f"更新答案 (索引: {ans_sim['index']})", key=f"update_{item['index']}_{ans_idx}"):
                                    success = kb.update_answer(ans_sim['index'], ans_sim['new_answer'])
                                    if success:
                                        ans_sim['action'] = 'updated'  # 标记已更新
                                        st.session_state.similarity_analysis = similarity_analysis
                                        st.success("✅ 答案已更新！")
                                        st.rerun()  # 刷新触发重新分类
                                    else:
                                        st.error("❌ 更新失败，请检查索引")
            else:
                st.info("✅ 暂无未更新的答案（已更新的内容已移至「已有问题」）")
        
        # 已有问题标签页【核心修改：显示问题+答案 + 相似问题（含问题+答案）】
        with tab_existing:
            if existing_questions:
                for idx, item in enumerate(existing_questions):
                    # 区分显示：是“已添加的新问题”还是“原有已处理问题”
                    tag = "🆕 已添加新问题" if item['is_new'] else "📌 原有问题"
                    with st.expander(f"{tag} | Q{item['index']+1}: {item['question'][:60]}{'...' if len(item['question'])>60 else ''}"):
                        st.markdown("**问题:**")
                        st.write(item['question'])
                        # 恢复：显示当前知识库中的答案
                        st.markdown("**当前知识库答案:**")
                        st.write(item['answer'])
                        # 显示处理状态
                        if item['is_new'] and item.get('action') == 'added':
                            st.success("✅ 状态：该新问题已成功添加到知识库")
                        else:
                            st.info("✅ 状态：该问题无需更新/所有更新已完成")
                        # 显示相似问题（如有，新增：完整显示相似问题的问题+答案，加分隔线）
                        if item.get('similar_questions') and not item['is_new']:
                            st.markdown("---")
                            st.markdown("### 匹配的知识库相似问题（含答案）")
                            for sim_q in item['similar_questions']:
                                st.markdown(f"**相似度: {sim_q['similarity']:.3f}**")
                                st.markdown(f"**匹配问题:** {sim_q['question']}")
                                st.markdown(f"**匹配答案:** {sim_q['answer']}")
                                st.markdown("---")  # 分隔线，清晰区分多个相似问题
            else:
                st.info("ℹ️ 暂无已有问题，请先处理「新问题」或「需要更新」的内容")
        
        # 批量操作（基于动态分类，仅处理未完成的内容）
        st.markdown("---")
        st.subheader("⚡ 批量操作")
        col1, col2, col3 = st.columns(3)
        with col1:
            # 批量添加：仅处理动态筛选的未添加新问题
            if len(new_questions) > 0:
                if st.button("批量添加所有新问题", type="primary"):
                    count = 0
                    for item in similarity_analysis:
                        if item['is_new'] and item.get('action') != 'added':
                            kb.add_qa_pair(item['question'], item['answer'])
                            item['action'] = 'added'
                            count += 1
                    kb.save_knowledge_base()
                    st.session_state.similarity_analysis = similarity_analysis
                    st.success(f"✅ 已批量添加 {count} 个新问题到知识库！")
                    st.rerun()
            else:
                st.info("✅ 暂无未添加的新问题")
        with col2:
            # 批量更新：仅处理动态筛选的未更新答案
            if len(update_questions) > 0:
                if st.button("批量更新所有需要更新的答案"):
                    count = 0
                    for item in similarity_analysis:
                        if not item['is_new'] and item.get('answer_similarities'):
                            for ans_sim in item['answer_similarities']:
                                if ans_sim['need_update'] and ans_sim.get('action') != 'updated':
                                    success = kb.update_answer(ans_sim['index'], ans_sim['new_answer'])
                                    if success:
                                        ans_sim['action'] = 'updated'
                                        count += 1
                    kb.save_knowledge_base()
                    st.session_state.similarity_analysis = similarity_analysis
                    st.success(f"✅ 已批量更新 {count} 个答案！")
                    st.rerun()
            else:
                st.info("✅ 暂无未更新的答案")
        with col3:
            if st.button("导出当前知识库"):
                kb.save_knowledge_base()
                kb_file = os.path.join(knowledge_base_path, "knowledge_base.json")
                with open(kb_file, 'r', encoding='utf-8') as f:
                    st.download_button(
                        '⬇️ 下载知识库',f.read(),'knowledge_base.json',
                        'application/json',key='download_kb'
                    )
    else:
        if not st.session_state.kb_instance:
            st.warning("⚠️ 知识库正在初始化中，请稍候...")
        if not st.session_state.kb_analysis_results:
            st.info("ℹ️ 请先选择并加载历史分析结果")
# ==================== 6. 页脚 ====================
st.markdown("---")
st.markdown("""
<div style="text-align: center; color: #666; font-size: 0.9em;">
    <p>© 知识沉淀系统</p>
</div>
""", unsafe_allow_html=True)