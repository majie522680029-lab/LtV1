# 读取结果目录的函数
def load_results(result_dir):
    """从结果目录加载处理结果"""
    try:
        # 加载统计信息
        stats_path = os.path.join(result_dir, "processing_stats.json")
        if os.path.exists(stats_path):
            with open(stats_path, 'r', encoding='utf-8') as f:
                stats = json.load(f)
        
        # 加载代表性QA
        rep_qa_path = os.path.join(result_dir, "representative_qa_pairs.json")
        if os.path.exists(rep_qa_path):
            with open(rep_qa_path, 'r', encoding='utf-8') as f:
                representative_qa = json.load(f)
        
        # 加载聚类结果，并统一数据结构
        cluster_path = os.path.join(result_dir, "cluster_results.json")
        clusters = {}
        if os.path.exists(cluster_path):
            with open(cluster_path, 'r', encoding='utf-8') as f:
                cluster_results = json.load(f)
                # 统一数据结构：直接使用 qa_pairs 列表
                for label_str, cluster_data in cluster_results["clusters"].items():
                    if isinstance(cluster_data, dict) and "qa_pairs" in cluster_data:
                        clusters[int(label_str) if label_str.lstrip('-').isdigit() else label_str] = cluster_data["qa_pairs"]
                    else:
                        clusters[int(label_str) if label_str.lstrip('-').isdigit() else label_str] = cluster_data
        
        # 修复：加载原始QA对
        raw_qa_path = os.path.join(result_dir, "raw_qa_pairs.json")
        all_qa_pairs = []
        if os.path.exists(raw_qa_path):
            with open(raw_qa_path, 'r', encoding='utf-8') as f:
                all_qa_pairs = json.load(f)
        
        return {
            'stats': stats,
            'representative_qa': representative_qa,
            'clusters': clusters,  # 确保是统一结构
            'all_qa_pairs': all_qa_pairs,
            'result_dir': result_dir
        }
    except Exception as e:
        st.error(f"加载结果失败: {str(e)}")
        return None

# 初始化BGE嵌入模型
def init_bge_embedding(config):
    """初始化BGE嵌入模型"""
    try:
        # 检查模型路径是否为空
        if not config["bge_model_path"] or config["bge_model_path"].strip() == "":
            st.error("❌ BGE模型路径不能为空，请在侧边栏配置")
            return None
        
        model = SentenceTransformer(config["bge_model_path"], device=config["embedding_device"])
        class EmbeddingGenerator:
            def __init__(self, model):
                self.model = model
            def get_embedding(self, text):
                return self.model.encode(text, normalize_embeddings=True, show_progress_bar=False)
        return EmbeddingGenerator(model)
    except Exception as e:
        st.error(f"初始化BGE模型失败: {str(e)}")
        return None

# 数据类型转换函数
def convert_numpy_types(obj):
    """递归转换 NumPy 数据类型为 Python 原生类型"""
    if isinstance(obj, (np.integer, np.int64, np.int32, np.int16, np.int8)):
        return int(obj)
    elif isinstance(obj, (np.floating, np.float64, np.float32, np.float16)):
        return float(obj)
    elif isinstance(obj, np.ndarray):
        return obj.tolist()
    elif isinstance(obj, dict):
        return {str(key): convert_numpy_types(value) for key, value in obj.items()}
    elif isinstance(obj, list):
        return [convert_numpy_types(value) for value in obj]
    else:
        return obj

# 自动初始化知识库函数
def auto_init_knowledge_base():
    """自动初始化知识库"""
    # 仅在未初始化或配置变更时执行
    if st.session_state.get('kb_auto_init_done', False):
        return
    
    # 创建配置字典
    config = {
        "bge_model_path": bge_model_path,
        "embedding_device": embedding_device
    }
    
    # 初始化嵌入模型
    embedding_generator = init_bge_embedding(config)
    if embedding_generator:
        st.session_state.embedding_generator = embedding_generator
        
        # 创建知识库目录
        os.makedirs(knowledge_base_path, exist_ok=True)
        
        # 初始化知识库
        kb = KnowledgeBase(knowledge_base_path, embedding_generator)
        st.session_state.kb_instance = kb
        
        # 标记初始化完成
        st.session_state.kb_auto_init_done = True
        
        st.success(f"✅ 知识库初始化成功！当前知识库包含 {len(kb.knowledge_base)} 个问答对")

