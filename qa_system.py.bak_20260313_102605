                if (enable_llm and deepseek_api_key and (judge_base_url or "").strip())
                else None
            )
            for i, qa in enumerate(representative_qa):
                status_text.info(f"分析 QA 对 {i+1}/{len(representative_qa)}")
                progress_bar.progress((i+1)/len(representative_qa))
                question = qa['representative_question']
                answer = qa['representative_answer']
                recalled_candidates = kb.find_similar_questions(question, similarity_threshold)
                display_candidates = recalled_candidates
                similar_questions = recalled_candidates
                if enable_llm and recalled_candidates:
                    display_candidates = []
                    similar_questions = []
                    for cand in recalled_candidates:
                        cand = dict(cand)
                        similarity_score = float(cand.get("similarity", 0.0))
                        triage_result = triage_gate_decision(similarity_score, resolved_t_low, resolved_t_high)
                        llm_called = triage_result["llm_called"]
                        final_decision = triage_result["final_decision"]
                        judge_result = {
                            "is_similar": bool(final_decision) if final_decision is not None else False,
                            "confidence": 1.0 if final_decision else 0.0,
                            "reason": triage_result["reason"]
                        }
                        if llm_called:
                            judge_result = judge_with_cache(
                                st.session_state,
                                question,
                                answer,
                                cand.get("question", ""),
                                cand.get("answer", ""),
                                judge_model,
                                deepseek_api_key,
                                judge_client,
                                judge_base_url.strip()
                            )
                            final_decision = judge_result.get("is_similar", False)
                            log_triage_event(
                                similarity_score,
                                resolved_t_low,
                                resolved_t_high,
                                triage_result["triage"],
                                llm_called,
                                final_decision,
                                judge_result.get("confidence"),
                                judge_result.get("reason")
                            )
                        else:
                            log_triage_event(
                                similarity_score,
                                resolved_t_low,
                                resolved_t_high,
                                triage_result["triage"],
                                llm_called,
                                final_decision,
                                judge_result.get("confidence"),
                                judge_result.get("reason")
                            )
                        cand["llm_judge"] = judge_result
                        cand["llm_is_similar"] = bool(final_decision)
                        cand["llm_confidence"] = judge_result.get("confidence", 0.0)
                        cand["llm_reason"] = judge_result.get("reason", "")
                        cand["triage"] = triage_result["triage"]
                        cand["llm_called"] = llm_called
                        cand["final_decision"] = bool(final_decision)
                        cand["triage_t_low"] = resolved_t_low
                        cand["triage_t_high"] = resolved_t_high
                        display_candidates.append(cand)
                        if final_decision:
                            similar_questions.append(cand)
                analysis_result = {
                    "index": i,
                    "question": question,
                    "answer": answer,
                    "display_candidates": display_candidates,
                    "similar_questions": similar_questions,
                    "is_new": len(similar_questions) == 0,
                    "has_manual_review_pending": False,
                    "action": None,  # 标记状态：added/updated/None
                    "selected_similar_index": None
                }
                # 计算答案相似度
                candidates_for_answer_compare = display_candidates if display_candidates else similar_questions
                if candidates_for_answer_compare:
                    answer_similarities = []
                    for sim_q in candidates_for_answer_compare:
                        question_sim = sim_q.get("similarity", 0.0)
                        ans_sim = kb.get_answer_embedding_similarity(answer, sim_q['answer'])
                        high_question_similarity = question_sim >= resolved_t_high
                        exact_question_match = normalize_compare_text(sim_q.get("question", "")) == normalize_compare_text(question)
                        answer_changed_for_same_question = (
                            exact_question_match and
                            normalize_compare_text(sim_q.get("answer", "")) != normalize_compare_text(answer)
                        )
                        need_manual_review = high_question_similarity and ans_sim < answer_similarity_threshold
                        need_update = answer_changed_for_same_question or (
                            ans_sim < answer_similarity_threshold and (
                                (not analysis_result["is_new"]) or need_manual_review
                            )
                        )
                        answer_similarities.append({
                            "answer_similarity": ans_sim,
                            "question_similarity": question_sim,
                            "need_update": need_update,
                            "need_manual_review": need_manual_review,
                            "exact_question_match": exact_question_match,
                            "answer_changed_for_same_question": answer_changed_for_same_question,
                            "existing_answer": sim_q['answer'],
                            "existing_question": sim_q.get("question", ""),
                            "new_answer": answer,
                            "index": sim_q['index'],
                            "action": None  # 标记答案更新状态
                        })
                    analysis_result["answer_similarities"] = answer_similarities
                    analysis_result["has_manual_review_pending"] = any(
                        ans.get("need_manual_review") and ans.get("action") != "updated"
                        for ans in answer_similarities
                    )
                similarity_analysis.append(analysis_result)
            progress_bar.empty()
            status_text.empty()
            return similarity_analysis

        def render_new_old_compare(new_q, new_a, old_q, old_a, question_sim=None, answer_sim=None, llm_info=None):
