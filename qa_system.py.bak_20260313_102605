        # 动态筛选函数，每次渲染都重新计算分类
        def get_dynamic_categories():
            new_qs = []
            update_qs = []
            existing_qs = []
            for x in similarity_analysis:
                answer_similarities = x.get('answer_similarities') or []
                has_pending_update = any(
                    ans.get('need_update') and ans.get('action') != 'updated'
                    for ans in answer_similarities
                )
                has_any_update_candidate = any(ans.get('need_update') for ans in answer_similarities)
                if has_pending_update:
                    update_qs.append(x)
                elif x['is_new'] and x.get('action') != 'added' and not has_any_update_candidate:
                    new_qs.append(x)
                else:
                    existing_qs.append(x)
            return new_qs, update_qs, existing_qs
        
        # 每次渲染都重新获取动态分类
