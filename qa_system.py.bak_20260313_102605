                                    new_a=item['answer'],
                                    old_q=sim_q.get('question', ''),
                                    old_a=sim_q.get('answer', ''),
                                    question_sim=sim_q.get('similarity'),
                                    answer_sim=(ans_sim or {}).get('answer_similarity'),
                                    llm_info=llm_info
                                )
            else:
                st.info("ℹ️ 暂无已有问题，请先处理「新问题」或「需要更新」的内容")
        
        # 批量操作（基于动态分类，仅处理未完成的内容）
        st.markdown("---")
        st.subheader("⚡ 批量操作")
        col1, col2, col3 = st.columns(3)
        with col1:
            # 批量添加：仅处理动态筛选的未添加新问题
            if len(new_questions) > 0:
                if st.button("批量添加所有新问题", type="primary"):
                    count_added = 0
                    count_updated = 0
                    count_unchanged = 0
                    for item in similarity_analysis:
                        if item['is_new'] and item.get('action') != 'added':
                            add_result = kb.add_qa_pair(item['question'], item['answer'])
                            item['action'] = 'added'
                            action = (add_result or {}).get("action")
                            if action == "updated":
                                count_updated += 1
                            elif action == "unchanged":
                                count_unchanged += 1
                            else:
                                count_added += 1
                    kb.save_knowledge_base()
                    st.session_state.similarity_analysis = similarity_analysis
                    if count_updated > 0:
                        push_replace_notice(
                            "批量添加",
                            f"检测到 {count_updated} 条同问题不同答案，已自动替换为新答案。"
                        )
                    st.success(
                        f"✅ 批量处理完成：新增 {count_added}，替换旧答案 {count_updated}，无变化 {count_unchanged}。"
                    )
                    st.rerun()
            else:
                st.info("✅ 暂无未添加的新问题")
        with col2:
            # 批量更新：仅处理动态筛选的未更新答案
            if len(update_questions) > 0:
                if st.button("批量更新所有需要更新的答案"):
                    count = 0
                    for item in similarity_analysis:
                        if not item['is_new'] and item.get('answer_similarities'):
                            for ans_sim in item['answer_similarities']:
                                if ans_sim['need_update'] and ans_sim.get('action') != 'updated':
                                    success = kb.update_answer(ans_sim['index'], ans_sim['new_answer'])
                                    if success:
                                        ans_sim['action'] = 'updated'
                                        count += 1
                    kb.save_knowledge_base()
                    st.session_state.similarity_analysis = similarity_analysis
                    if count > 0:
                        push_replace_notice(
                            "批量更新",
                            f"已替换 {count} 条旧答案为新答案。"
                        )
                    st.success(f"✅ 已批量更新 {count} 个答案！")
                    st.rerun()
            else:
                st.info("✅ 暂无未更新的答案")
        with col3:
            if st.button("导出当前知识库"):
                kb.save_knowledge_base()
                kb_file = os.path.join(knowledge_base_path, "knowledge_base.json")
                with open(kb_file, 'r', encoding='utf-8') as f:
                    st.download_button(
                        '⬇️ 下载知识库',f.read(),'knowledge_base.json',
                        'application/json',key='download_kb'
                    )
    else:
        if not st.session_state.kb_instance:
            st.warning("⚠️ 知识库正在初始化中，请稍候...")
        if not st.session_state.kb_analysis_results:
            st.info("ℹ️ 请先选择并加载历史分析结果")
