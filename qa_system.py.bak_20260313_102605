# ==================== 新增：知识库类 ====================
class KnowledgeBase:
    def __init__(self, path, embedding_generator):
        self.path = path
        self.embedding_generator = embedding_generator
        self.knowledge_base = []
        self.load_knowledge_base()
    
    def load_knowledge_base(self):
        """从文件加载知识库"""
        kb_file = os.path.join(self.path, "knowledge_base.json")
        if os.path.exists(kb_file):
            try:
                with open(kb_file, 'r', encoding='utf-8') as f:
                    self.knowledge_base = json.load(f)
                st.info(f"✅ 加载知识库，包含 {len(self.knowledge_base)} 个问题")
            except Exception as e:
                st.warning(f"⚠️ 加载知识库失败: {str(e)}")
        else:
            st.info("ℹ️ 知识库文件不存在，将创建新知识库")
            self.knowledge_base = []
    
    def save_knowledge_base(self):
        """保存知识库到文件"""
        kb_file = os.path.join(self.path, "knowledge_base.json")
        try:
            with open(kb_file, 'w', encoding='utf-8') as f:
                json.dump(self.knowledge_base, f, ensure_ascii=False, indent=2)
        except Exception as e:
            st.error(f"❌ 保存知识库失败: {str(e)}")
    
    def add_qa_pair(self, question, answer, embedding=None):
        """添加问答对；若问题已存在且答案不同，则直接替换旧答案。"""
        normalized_question = normalize_compare_text(question)
        normalized_answer = normalize_compare_text(answer)
        now_str = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        for idx, item in enumerate(self.knowledge_base):
            existing_question = normalize_compare_text(item.get("question", ""))
            if existing_question == normalized_question:
                old_answer = item.get("answer", "")
                existing_answer = normalize_compare_text(item.get("answer", ""))
                if existing_answer != normalized_answer:
                    self.knowledge_base[idx]["answer"] = answer
                    self.knowledge_base[idx]["updated_at"] = now_str
                    return {
                        "action": "updated",
                        "index": idx,
                        "question": question,
                        "old_answer": old_answer,
                        "new_answer": answer
                    }
                return {"action": "unchanged", "index": idx}

        if embedding is None:
            embedding = self.embedding_generator.get_embedding(question)
        self.knowledge_base.append({
            "question": question,
            "answer": answer,
            "embedding": embedding.tolist() if hasattr(embedding, 'tolist') else embedding,
            "created_at": now_str,
            "updated_at": now_str
        })
        return {"action": "added", "index": len(self.knowledge_base) - 1}
    
    def find_similar_questions(self, question, similarity_threshold=0.7):
        """查找与给定问题相似的现有问题"""
        if not self.knowledge_base:
            return []
            
        question_embedding = self.embedding_generator.get_embedding(question)
        similar_items = []
        
        for item in self.knowledge_base:
            # 计算相似度
            similarity = 1 - cosine_distances([question_embedding], [item["embedding"]])[0][0]
            
            if similarity >= similarity_threshold:
                similar_items.append({
                    "similarity": similarity,
                    "question": item["question"],
                    "answer": item["answer"],
                    "created_at": item["created_at"],
                    "updated_at": item.get("updated_at", ""),
                    "index": self.knowledge_base.index(item)
                })
        
        # 按相似度排序
        similar_items.sort(key=lambda x: x["similarity"], reverse=True)
        return similar_items
    
    def update_answer(self, index, new_answer):
        """更新知识库中指定索引的问答对答案"""
        if 0 <= index < len(self.knowledge_base):
            self.knowledge_base[index]["answer"] = new_answer
            self.knowledge_base[index]["updated_at"] = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            return True
        return False
    
    def get_answer_embedding_similarity(self, answer1, answer2):
        """计算两个答案的语义相似度"""
        emb1 = self.embedding_generator.get_embedding(answer1)
        emb2 = self.embedding_generator.get_embedding(answer2)
        return 1 - cosine_distances([emb1], [emb2])[0][0]

