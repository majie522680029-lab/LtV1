                st.session_state.show_llm_compare = True
        st.caption("对比视图会区分：LLM 判定（灰区）与规则直判（HIGH/LOW）。")

        if st.session_state.show_llm_compare and st.session_state.similarity_analysis_no_llm and st.session_state.similarity_analysis_with_llm:
