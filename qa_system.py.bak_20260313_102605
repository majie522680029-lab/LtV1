def classify_api_exception(exc):
    """将 API 异常分类为可诊断标签。"""
    error_type = type(exc).__name__
    def _build_exception_chain_message(err):
        parts = []
        seen = set()
        current = err
        while current is not None and id(current) not in seen:
            seen.add(id(current))
            text = (str(current).strip() or repr(current))
            parts.append(f"{type(current).__name__}: {text}")
            current = getattr(current, "__cause__", None) or getattr(current, "__context__", None)
        return " | ".join(parts)

    message = _build_exception_chain_message(exc)
    lower_message = message.lower()
    status_code = getattr(exc, "status_code", None)
    response_obj = getattr(exc, "response", None)
    if status_code is None and response_obj is not None:
        status_code = getattr(response_obj, "status_code", None)

    category = "UNKNOWN"
    label = "未知错误"
    hint = "请查看控制台详细日志定位问题"

    timeout_error_names = {"APITimeoutError", "ConnectTimeout", "ReadTimeout", "TimeoutException"}
    dns_signals = (
        "temporary failure in name resolution",
        "name or service not known",
        "nodename nor servname",
        "getaddrinfo",
        "dns"
    )
    proxy_signals = ("proxy", "tunnel connection failed", "proxyerror")
    connection_signals = ("connection error", "connection refused", "failed to establish a new connection")

    if status_code == 401:
        category = "HTTP_401"
        label = "401 认证失败"
        hint = "请检查 API Key 是否正确、是否过期或是否有权限访问该模型"
    elif status_code == 429:
        category = "HTTP_429"
        label = "429 频率/配额限制"
        hint = "可能触发限流或账户配额不足，请稍后重试并检查配额"
    elif status_code is not None:
        category = f"HTTP_{status_code}"
        label = f"{status_code} 接口错误"
        hint = "请检查请求参数、模型名称以及服务端状态"
    elif error_type in timeout_error_names or "timeout" in lower_message or "timed out" in lower_message:
        category = "TIMEOUT"
        label = "连接超时"
        hint = "请检查网络质量、代理链路，并确认服务端响应是否稳定"
    elif any(signal in lower_message for signal in dns_signals):
        category = "DNS"
        label = "DNS 解析失败"
        hint = "请检查域名解析设置和网络出口 DNS"
    elif any(signal in lower_message for signal in proxy_signals):
        category = "PROXY"
        label = "代理异常"
        hint = "请检查 http_proxy/https_proxy 配置及本地代理进程"
    elif "apiconnectionerror" in error_type.lower() or any(signal in lower_message for signal in connection_signals):
        category = "CONNECTION"
        label = "连接失败"
        hint = "请检查 API 地址、网络连通性或代理链路"

    return {
        "category": category,
        "label": label,
        "hint": hint,
        "status_code": status_code,
        "error_type": error_type,
        "message": message
    }


def report_api_exception(scene, exc, request_url=None):
    """输出标准化日志并在前端提示可诊断错误信息。"""
    info = classify_api_exception(exc)
    proxy_http = os.getenv("HTTP_PROXY") or os.getenv("http_proxy") or ""
    proxy_https = os.getenv("HTTPS_PROXY") or os.getenv("https_proxy") or ""
    proxy_no = os.getenv("NO_PROXY") or os.getenv("no_proxy") or ""
    payload = {
        "scene": scene,
        "request_url": request_url or "",
        "category": info["category"],
        "status_code": info["status_code"],
        "error_type": info["error_type"],
        "message": info["message"],
        "hint": info["hint"],
        "http_proxy": proxy_http,
        "https_proxy": proxy_https,
        "no_proxy": proxy_no
    }
    print(f"[api_error] {json.dumps(payload, ensure_ascii=False)}")
    status_suffix = f"（HTTP {info['status_code']}）" if info["status_code"] is not None else ""
    st.toast(f"⚠️ {scene}失败: {info['label']} {status_suffix}")
    st.caption(f"{info['hint']} | 详情: {info['message']}")
    if info["category"] in {"CONNECTION", "PROXY", "TIMEOUT", "DNS"}:
        st.caption(
            f"请求地址: {request_url or 'N/A'} | HTTP_PROXY={proxy_http or '空'} | "
            f"HTTPS_PROXY={proxy_https or '空'} | NO_PROXY={proxy_no or '空'}"
        )


def parse_optional_threshold(raw_value, field_name):
    """解析可选阈值输入；空字符串表示未显式配置。"""
    text_value = (raw_value or "").strip()
    if text_value == "":
        return None
    try:
        threshold = float(text_value)
    except ValueError:
        st.error(f"❌ {field_name} 必须是 0~1 的数字，当前输入: {raw_value}")
        st.stop()
    if not (0.0 <= threshold <= 1.0):
        st.error(f"❌ {field_name} 必须在 0~1 之间，当前输入: {raw_value}")
        st.stop()
    return threshold


def resolve_triage_thresholds(t_llm_gate, triage_t_low, triage_t_high):
    """解析 triage 阈值，兼容旧单阈值配置。"""
    derived = False
    t_low = triage_t_low
    t_high = triage_t_high
    if t_low is None and t_high is None:
        t_low = t_llm_gate
        t_high = min(1.0, t_low + 0.08)
        derived = True
    else:
        if t_low is None:
            t_low = t_llm_gate
            derived = True
        if t_high is None:
            t_high = min(1.0, t_low + 0.08)
            derived = True

    if t_high <= t_low:
        adjusted_high = min(1.0, t_low + 0.05)
        if adjusted_high <= t_low:
            st.error(f"❌ triage 阈值非法：T_HIGH({t_high:.3f}) 必须大于 T_LOW({t_low:.3f})")
            st.stop()
        print(
            f"[triage_gate] warning: invalid thresholds detected; "
            f"auto-adjust T_HIGH from {t_high:.3f} to {adjusted_high:.3f}"
        )
        t_high = adjusted_high

    if derived:
        print(
            f"[triage_gate] using derived triage thresholds: "
            f"T_LOW={t_low:.3f}, T_HIGH={t_high:.3f}, source_t_llm_gate={t_llm_gate:.3f}"
        )
    else:
        print(
            f"[triage_gate] using explicit triage thresholds: "
            f"T_LOW={t_low:.3f}, T_HIGH={t_high:.3f}"
        )
    return t_low, t_high


def log_triage_event(sim, t_low, t_high, triage, llm_called, final_decision, confidence=None, reason=None):
    """输出 triage 决策日志，便于观测门控行为。"""
    log_payload = {
        "sim": round(float(sim), 6),
        "T_LOW": round(float(t_low), 6),
        "T_HIGH": round(float(t_high), 6),
        "triage": triage,
        "llm_called": bool(llm_called),
        "final_decision": bool(final_decision)
    }
    if confidence is not None:
        log_payload["confidence"] = round(float(confidence), 6)
    if reason is not None:
        log_payload["reason"] = reason
    print(f"[triage_gate] {json.dumps(log_payload, ensure_ascii=False)}")


