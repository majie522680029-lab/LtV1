        # 已有问题标签页【核心修改：显示问题+答案 + 相似问题（含问题+答案）】
        with tab_existing:
            if existing_questions:
                for idx, item in enumerate(existing_questions):
                    # 区分显示：是“已添加的新问题”还是“原有已处理问题”
                    tag = "🆕 已添加新问题" if item['is_new'] else "📌 原有问题"
